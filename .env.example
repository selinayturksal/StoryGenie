# ── Sunucu ──
PORT=5000
CLIENT_URL=http://localhost:3000

# ── MongoDB ──
MONGODB_URI=mongodb+srv://kullanici:sifre@cluster.mongodb.net/masalmatik

# ── JWT ──
JWT_SECRET=gizli_jwt_anahtari_buraya

# ── Mail (Gmail SMTP) ──
# Gmail App Password için: Google Hesabı > Güvenlik > 2 Adımlı Doğrulama > Uygulama Şifreleri
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM="MasalMatik <your_gmail@gmail.com>"
# İletişim formu — formdan gelen mesajlar bu adrese iletilir (boş bırakılırsa MAIL_FROM kullanılır)
SUPPORT_EMAIL=your_gmail@gmail.com
APP_URL=http://localhost:3000

# ── AWS Bedrock ──
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
